# OpenRouter
# Chat and VLM calls
OPENROUTER_API_KEY=

# Nvidia NIM
# Used for embeddings (nvidia/nv-embed-v2)
NVIDIA_API_KEY=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=stateful-pdf-chat
LANGSMITH_TRACING=true

# Temporal
TEMPORAL_HOST=localhost:7233

# Qdrant (local disk)
QDRANT_PATH=./local_research_db
DB_COLLECTION=research_papers

# Models
VLM_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1
CHAT_MODEL=deepseek/deepseek-chat
EMBED_MODEL=baai/bge-m3

# Ingestion
PAPERS_DIR=./research_papers
